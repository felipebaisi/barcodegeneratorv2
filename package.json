{
  "name": "node-barcode-helper",
  "version": "1.0.0",
  "description": "Production-ready Node.js barcode generator (PDF417, Code 39/VIN, QR) with CLI and REST API",
  "main": "dist/server/app.js",
  "bin": {
    "barcode-gen": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server/app.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server/app.ts",
    "cli": "ts-node src/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "barcode",
    "pdf417",
    "code39",
    "qrcode",
    "vin",
    "generator",
    "cli",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bwip-js": "^4.5.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
